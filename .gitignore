# macOS
.DS_Store
._*

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets and credentials
.env
.env.local
*.env
!*.env.example
nut-credentials.txt
secrets/

# Host-specific configs (only *.example templates are tracked)
config/*.conf
!config/*.example

# Local nut-webgui config (only the .example template is tracked)
docker/nut-webgui.toml

# Backups created by setup scripts
backup-*/
*.bak
*.orig

# Logs
*.log
logs/*
!logs/.gitkeep

# Go build artifacts
bin/
dist/
coverage.out
coverage.html
*.test
*.prof

# Docs site (apps/docs/)
apps/docs/node_modules/
apps/docs/.docusaurus/
apps/docs/build/
apps/docs/test-results/
apps/docs/playwright-report/
apps/docs/playwright/.cache/
