# NUT Docker Configuration (Path A: monitoring-only stack)
# Copy this file to .env and customize values.
#
# The Docker stack connects to an EXTERNAL NUT server — typically the
# bare-metal nut-server running on the Docker host. The UPS itself is
# managed by that server, not by Docker.

# ===========================================
# NUT Server (external, scraped by nut-exporter)
# ===========================================

# Hostname or IP of the NUT server.
# Use host.docker.internal for the bare-metal NUT server on this host.
# Use a LAN IP (e.g. 192.0.2.10) if NUT runs on a different machine.
NUT_HOST=host.docker.internal

# UPS name configured in /etc/nut/ups.conf on the NUT server
UPS_NAME=myups

# ===========================================
# Grafana
# ===========================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ===========================================
# Ports (change if conflicts exist)
# ===========================================

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
