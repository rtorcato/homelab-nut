# NUT Docker Configuration (Path A)
# Copy this file to .env and customize values.
#
# The Docker stack connects to an EXTERNAL NUT server — typically the
# bare-metal nut-server running on the Docker host. The UPS itself is
# managed by that server, not by Docker.
#
# Services in compose.yml:
#   nut-exporter  - Prometheus metrics endpoint (scraped by remote Prometheus)
#   nut-webgui    - Web UI for the bare-metal NUT server

# ===========================================
# NUT Server (external, scraped by nut-exporter)
# ===========================================

# Hostname or IP of the NUT server.
# Use host.docker.internal for the bare-metal NUT server on this host.
# Use a LAN IP (e.g. 192.0.2.10) if NUT runs on a different machine.
NUT_HOST=host.docker.internal

# UPS name configured in /etc/nut/ups.conf on the NUT server
UPS_NAME=myups

# ===========================================
# NUT credentials (used by nut-webgui)
# ===========================================
# These must match a user defined in /etc/nut/upsd.users on the NUT server.
# Grab them from /root/nut-credentials.txt on the host (created by setup-server.sh).
# For read-only status views, the upsmon user is enough. To issue INSTCMD/FSD
# from the web UI, use a user with the appropriate privileges (e.g. admin).
NUT_API_USER=upsmon
NUT_API_PASSWORD=changeme_monitor_password

# ===========================================
# Ports (change if conflicts exist)
# ===========================================

# Port the nut-exporter publishes on the host.
# Remote Prometheus scrapes this.
NUT_EXPORTER_PORT=9199

# Web UI port — open http://<host>:<port>
NUT_WEBGUI_PORT=9000
