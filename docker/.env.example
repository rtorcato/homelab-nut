# NUT Docker Configuration
# Copy this file to .env and customize values

# ===========================================
# UPS Configuration
# ===========================================

# UPS name (used in NUT commands like: upsc myups@localhost)
UPS_NAME=myups

# UPS driver (see: https://networkupstools.org/stable-hcl.html)
# Common drivers: usbhid-ups, apcsmart, blazer_usb, nutdrv_qx
UPS_DRIVER=usbhid-ups

# UPS description (for display purposes)
UPS_DESCRIPTION=My UPS

# Optional: USB Vendor ID (uncomment if auto-detection fails)
# Find with: lsusb | grep -i ups
# UPS_VENDORID=051d

# ===========================================
# NUT Credentials
# ===========================================

# Monitor user credentials (used by clients to read UPS status)
NUT_API_USER=upsmon
NUT_API_PASSWORD=changeme_monitor_password

# Admin credentials (used for upscmd/upsrw commands)
NUT_ADMIN_PASSWORD=changeme_admin_password

# ===========================================
# Grafana (full-stack only)
# ===========================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ===========================================
# Ports (change if conflicts exist)
# ===========================================

NUT_PORT=3493
WEBNUT_PORT=6543
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
NUT_EXPORTER_PORT=9199
